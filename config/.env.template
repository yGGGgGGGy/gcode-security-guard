# Gcode 环境变量模板
# cp config/.env.template .env && 按需修改

# === 意图过滤 (m1) ===
GCODE_SOCKET=/run/gcode/gcode.sock
GCODE_AUDIT_DB=/data/gcode_audit.db
GCODE_INTENT_THRESHOLD=0.6
GCODE_INTENT_MODEL=Qwen/Qwen2.5-0.5B

# === MCP Server (dp1) ===
GCODE_MCP_SOCKET=/run/gcode/gcode-dp1.sock
GCODE_SANDBOX=podman
GCODE_TOOL_TIMEOUT=30

# === 推理层 (LLM) ===
# GCODE_LLM_PROVIDER=qwen
# GCODE_LLM_API_KEY=
# GCODE_LLM_MODEL=qwen-plus
# GCODE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# === 审计 ===
GCODE_AUDIT_RETENTION_DAYS=90
