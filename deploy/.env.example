# Gcode 环境变量配置
# 复制为 /opt/gcode/.env 并根据环境修改

# Python 配置
PYTHONUNBUFFERED=1

# 配置文件路径
GCODE_CONFIG=/etc/gcode/config.yaml

# 日志目录
GCODE_LOG_DIR=/var/log/gcode

# 模型缓存目录（HuggingFace 模型下载路径）
HF_HOME=/opt/gcode/models

# MCP Server socket 路径
GCODE_MCP_SOCKET=/run/gcode/gcode-dp1.sock

# Security Guard socket 路径
GCODE_GUARD_SOCKET=/run/gcode/gcode.sock
